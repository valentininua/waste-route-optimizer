DATABASE_URL=postgresql+psycopg://waste:waste@postgres:5432/waste_routes
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_EMAIL=work@valentin.in.ua
OSRM_URL=https://router.project-osrm.org
DEFAULT_CITY=Jelgava
DEFAULT_COUNTRY=Latvia
APP_USER_AGENT=waste-route-optimizer/1.16 (contact: work@valentin.in.ua)

# Demo-safe mode. Disable these for strict production validation.
ALLOW_APPROXIMATE_GEOCODING_FALLBACK=true
ALLOW_HAVERSINE_FALLBACK=true
ALLOW_APPROXIMATE_MATRIX_FOR_LARGE_ROUTES=true

MAX_PUBLIC_OSRM_TABLE_POINTS=100
MAX_OSRM_ROUTE_WAYPOINTS=80
MAX_POINTS_TO_OPTIMIZE=450
GEOCODING_SLEEP_SECONDS=1.1
APPROXIMATE_CENTER_LAT=56.6511
APPROXIMATE_CENTER_LNG=23.7214
